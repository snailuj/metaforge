    handle /thesaurus/* {
        reverse_proxy 127.0.0.1:8080
    }
    handle /forge/* {
        reverse_proxy 127.0.0.1:8080
    }
    handle /strings/* {
        reverse_proxy 127.0.0.1:8080
    }
    handle /health {
        reverse_proxy 127.0.0.1:8080
    }
    handle {
        root * __WORKTREE__/web/dist
        try_files {path} /index.html
        file_server
    }
}
